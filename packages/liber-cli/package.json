{
  "name": "liber-cli",
  "version": "0.1.0",
  "description": "Agent-friendly CLI for validating and packaging CC0/public-domain EPUB books for Liber.",
  "type": "module",
  "bin": {
    "liber": "bin/liber.mjs"
  },
  "exports": {
    ".": "./src/liber-core.mjs"
  },
  "files": [
    "bin/",
    "src/",
    "README.md"
  ],
  "scripts": {
    "cli": "node bin/liber.mjs",
    "test": "node --test test/*.test.mjs",
    "pack:dry-run": "npm pack --dry-run"
  },
  "keywords": [
    "liber",
    "epub",
    "cc0",
    "public-domain",
    "books",
    "agent"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  }
}
