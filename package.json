{
  "name": "liber",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Liber — 永存的开放图书馆. A decentralized, AI-agent-friendly reading platform for CC0 books.",
  "workspaces": [
    "packages/liber-cli"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.json",
    "cf-typegen": "wrangler types --env-interface Env",
    "postinstall": "npm run cf-typegen",
    "format": "biome format --write .",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "cli": "npm --workspace liber-cli run cli --",
    "smoke:real-content": "node scripts/real-content-smoke.mjs",
    "import:pd-texts": "node scripts/import-public-domain-texts.mjs",
    "import:gutenberg-classics": "node scripts/import-gutenberg-classics.mjs",
    "import:wikisource-classics": "node scripts/import-wikisource-classics.mjs",
    "import:wikisource-classics:fast": "node scripts/import-wikisource-classics.mjs --publish --skip-existing --continue-on-error --summary --json --quiet --no-live-probe --concurrency 10 --chapter-concurrency 16 --publish-attempts 10 --publish-timeout-ms 45000",
    "audit:gutenberg-catalog": "node scripts/import-gutenberg-classics.mjs --audit --summary --json",
    "test:cli": "npm --workspace liber-cli test",
    "pack:cli": "npm --cache ./.npm-cache --workspace liber-cli pack --dry-run",
    "test:ui": "node --test test/*.test.mjs",
    "test:ts": "node --import tsx --test test/*.test.ts",
    "test": "npm run typecheck && npm run test:ui && npm run test:ts && npm run test:cli",
    "dev:api": "npm run build && wrangler pages dev",
    "deploy": "npm run build && wrangler pages deploy",
    "platform:deploy": "wrangler deploy --config wrangler.platform.toml",
    "platform:dev": "wrangler dev --config wrangler.platform.toml --remote",
    "graph:spike": "node scripts/echo-spike.mjs",
    "db:migrate:local": "node scripts/migrate.mjs --local",
    "db:migrate": "node scripts/migrate.mjs --remote",
    "db:migrate:baseline": "node scripts/migrate.mjs --remote --baseline",
    "db:migrate:local:baseline": "node scripts/migrate.mjs --local --baseline",
    "db:migrate:plan": "node scripts/migrate.mjs --dry-run"
  },
  "dependencies": {
    "@mysten/sui": "^2.17.0",
    "@mysten/wallet-standard": "^0.20.3",
    "@noble/curves": "^2.2.0",
    "@noble/hashes": "^2.2.0",
    "@scure/base": "^2.2.0",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.1",
    "@tanstack/react-query": "^5.100.14",
    "@tanstack/react-router": "^1.170.10",
    "@tanstack/react-store": "^0.11.0",
    "@tanstack/react-virtual": "^3.14.2",
    "@tanstack/store": "^0.11.0",
    "epubjs": "0.3.93",
    "hono": "^4.6.14",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@cloudflare/workers-types": "^4.20241127.0",
    "@vitejs/plugin-react": "^4.3.4",
    "tsx": "^4.22.4",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "wrangler": "^3.90.0"
  },
  "overrides": {
    "epubjs": {
      "@xmldom/xmldom": "0.8.13"
    }
  }
}
